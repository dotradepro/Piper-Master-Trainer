# Piper Master Trainer - Environment Variables

# Backend
DATABASE_URL=sqlite+aiosqlite:///./storage/db.sqlite3
REDIS_URL=redis://localhost:6379/0
STORAGE_PATH=./storage
SECRET_KEY=change-me-in-production

# GPU
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Training defaults
DEFAULT_BATCH_SIZE=4
DEFAULT_PRECISION=16-mixed
DEFAULT_ACCUMULATE_GRAD_BATCHES=8
DEFAULT_MAX_EPOCHS=10000
DEFAULT_SAMPLE_RATE=22050

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Piper
PIPER_GPL_PATH=/opt/piper1-gpl
